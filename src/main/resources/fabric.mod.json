{
  "schemaVersion": 1,
  "id": "methanium",
  "version": "${version}",
  "name": "Methanium",
  "description": "Vulkan renderer optimizer for Minecraft 26.2. Squeezes maximum stable FPS by cutting CPU overhead, culling invisible geometry, and tuning Minecraft's experimental Vulkan backend path.",
  "authors": [
    "Methanium Contributors"
  ],
  "contact": {
    "sources": "https://github.com/your-name/methanium"
  },
  "license": "MIT",
  "icon": "assets/methanium/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "dev.methanium.MethaniumMod"
    ]
  },
  "mixins": [
    "methanium.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.19.3",
    "minecraft": "~26.2",
    "java": ">=25",
    "fabric-api": "*"
  },
  "suggests": {},
  "custom": {
    "modmenu:badges": ["optimization"]
  }
}
